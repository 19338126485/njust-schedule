	</body>
<script type="text/javascript">
var app_service = "";
var serverPrefix = "https://ids.njust.edu.cn/authserver";
var isLogin = "";
var isMobile = "false";
$(function(){
	var hislen=2;
	if ((navigator.userAgent.indexOf('MSIE') >= 0) && (navigator.userAgent.indexOf('Opera') < 0)){ // IE
		hislen=1;
	}
	if(history.length < hislen){
		document.getElementById("back").style.display="none";
	}
	
	if(isLogin == "true"){
        //$("#backBtn").on("click",logoutBtn());
        //$("#backBtn").removeAttr("href");
        $("#logoutBtn").show();
	}
});

function logoutBtn(){
    if (app_service) {
        window.location.href = serverPrefix+"/logout?service="+encodeURIComponent(app_service);
    }else{
        window.location.href = serverPrefix+"/logout?service="+encodeURIComponent(serverPrefix+"/login");
    }
}
</script>
