	<body id="bg" style="width: auto">
		<div class="ui_container_fluid">
		    <div class="header">
		        <div class="top">
		            <div class="logo pull_left">
		                <img id="logo" class="top-logo-img-maxHeightWidth" alt="IDS logo" title="IDS logo"/></div>
		        </div>
		    </div>
