</span>
    <div class="tab-content warn-content">
        <div class="ibox-content">
            <div id="welcome" class="warn">
                <h4>哎呦，出错啦</h4>
                <p>请求不合法，请联系管理员！</p>
            </div>
            <div class="welcome-button">
                <p id="back" style="text-align: center">
                    <a id="backBtn" href="javascript:history.back();" class="btn btn-primary">返回</a>
                    <a id="logoutBtn" href="javascript:void(0);" onclick="logoutBtn()" style="display: none;" class="btn logout-btn-primary">请重新登录</a>
                </p>
            </div>
        </div>
    </div>
    <!--尾：移动端访问页面--><!--尾：iframe嵌入页面类型--><!--尾：普通的web访问类型--><div class="clearfloat"></div>
